# Copy to .env and fill in the values marked REQUIRED.

# --- Anthropic (REQUIRED) ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-5

# --- Database ---
DATABASE_URL=postgresql+psycopg://screening:screening@localhost:5432/screening

# --- Rate limiting ---
# Leave empty for in-memory rate limiting (fine for a single backend process/container).
# Set once you run more than one backend replica, so limits are enforced globally
# instead of separately per replica.
REDIS_URL=

# --- Auth (REQUIRED) ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
FORCE_EMAIL_VERIFICATION=false

# --- Security ---
# APP_ENV: set to "production" in live deployments to enable startup security warnings.
APP_ENV=development

# Admin API key — protects /api/admin/* (knowledge base ingest/rebuild).
# Two modes (use one):
#   ADMIN_API_KEY_HASH (preferred): store only the SHA-256 hex-digest so the raw key
#   never lives in the process. To rotate: generate a new key, hash it, update this var.
#   Generate:  echo -n 'my-long-random-admin-key' | sha256sum
ADMIN_API_KEY_HASH=
#   ADMIN_API_KEY (legacy plaintext — simpler for local dev):
ADMIN_API_KEY=

ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# HSTS: set to 31536000 (1 year) on any HTTPS deployment (Render, Fly, Railway, etc.).
# Leave at 0 for local HTTP dev so the browser's HSTS cache is not poisoned.
SECURITY_HSTS_SECONDS=0

# --- Email (leave SMTP_HOST empty to just log emails locally) ---
APP_BASE_URL=http://localhost:3000
EMAIL_FROM=noreply@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# --- Observability ---
# Leave SENTRY_DSN empty to disable error tracking (e.g. in local dev/tests).
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# JSON logs (for log aggregators); plain text is easier to read locally.
LOG_JSON=false

# --- RAG / ChromaDB (defaults are usually fine) ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RETRIEVAL=5

# --- Interview ---
MAX_QUESTIONS=8

DEBUG=false
